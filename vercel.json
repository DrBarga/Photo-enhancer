{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": ".",
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "framework": "fastapi",
      "routePrefix": "/api",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": [
        "backend/app/**",
        "backend/index.py",
        "backend/requirements.txt"
      ]
    }
  }
}
